# ============================================================
# Variables de entorno — CosmicEngine PRODUCCION
# ============================================================
# Copiar como .env.prod y completar con valores reales.
# NUNCA commitear .env.prod al repositorio.
# ============================================================

# --- Base de datos ---
POSTGRES_USER=cosmic
POSTGRES_PASSWORD=GENERAR-CON-openssl-rand-hex-32
POSTGRES_DB=cosmicengine
DATABASE_URL=postgresql+asyncpg://cosmic:TU_PASSWORD@postgres:5432/cosmicengine
DATABASE_URL_SYNC=postgresql+psycopg2://cosmic:TU_PASSWORD@postgres:5432/cosmicengine

# --- Redis ---
REDIS_PASSWORD=GENERAR-CON-openssl-rand-hex-32
REDIS_URL=redis://:TU_REDIS_PASSWORD@redis:6379/0

# --- Efemerides ---
EPHE_PATH=/app/datos_efemerides

# --- Aplicacion ---
AMBIENTE=produccion
LOG_LEVEL=WARNING
VERSION=1.0.0

# --- Dominio y CORS ---
DOMINIO=tu-dominio.com
CORS_ORIGINS=https://tu-dominio.com

# --- JWT (OBLIGATORIO: generar clave unica) ---
CLAVE_SECRETA=GENERAR-CON-openssl-rand-hex-64
ALGORITMO_JWT=HS256
EXPIRACION_TOKEN_ACCESO=30
EXPIRACION_TOKEN_REFRESCO=10080

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tu-dominio.com/callback

# --- MercadoPago ---
MP_ACCESS_TOKEN_AR=
MP_PUBLIC_KEY_AR=
MP_ACCESS_TOKEN_BR=
MP_PUBLIC_KEY_BR=
MP_ACCESS_TOKEN_MX=
MP_PUBLIC_KEY_MX=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=https://tu-dominio.com/api/v1/suscripcion/webhook
MP_URL_EXITO=https://tu-dominio.com/suscripcion/exito
MP_URL_FALLO=https://tu-dominio.com/suscripcion/fallo
MP_URL_PENDIENTE=https://tu-dominio.com/suscripcion/pendiente

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODELO=claude-sonnet-4-20250514

# --- Gemini ---
GEMINI_API_KEY=

# --- MinIO / S3 ---
MINIO_ACCESS_KEY=GENERAR-CON-openssl-rand-hex-16
MINIO_SECRET_KEY=GENERAR-CON-openssl-rand-hex-32
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=astra-podcasts
MINIO_SECURE=false

# --- Frontend (variable de build) ---
NEXT_PUBLIC_API_URL=https://tu-dominio.com
